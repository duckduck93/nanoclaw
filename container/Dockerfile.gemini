# NanoClaw Gemini Agent Container
# Runs gemini-cli in isolated environment with per-channel workspace

FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install gemini-cli globally
RUN npm install -g @google/gemini-cli

# Build gemini-runner
WORKDIR /app
COPY gemini-runner/package*.json ./
RUN npm install
COPY gemini-runner/ ./
RUN npm run build

CMD ["node", "dist/index.js"]
